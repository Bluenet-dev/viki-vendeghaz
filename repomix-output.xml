      <p className="text-xs text-bark/40 text-center">
        Az adatkezelési tájékoztatót{" "}
        <a href="/adatvedelem" className="underline hover:text-bark/60">itt</a>{" "}
        olvashatja.
      </p>
    </form>
  );
}


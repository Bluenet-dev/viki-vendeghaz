}

async function deleteFaq(formData: FormData) {
  "use server";
  await db.delete(faq).where(eq(faq.id, Number(formData.get("id"))));
  revalidatePath("/admin/gyik");
}

async function toggleFaq(formData: FormData) {
  "use server";
  const id = Number(formData.get("id"));

          )}
          <h1 className="font-display text-4xl sm:text-5xl text-stone font-light mb-4 leading-tight">
            {post.title}
          </h1>
          {post.publishedAt && (
            <p className="text-mist/50 text-sm font-mono">
              {new Date(post.publishedAt).toLocaleDateString("hu-HU", {
                year: "numeric",
                month: "long",
                day: "numeric",

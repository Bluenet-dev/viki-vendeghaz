      {/* Borítókép */}
      {post.coverImageUrl && (
        <div className="relative w-full aspect-[16/7] bg-ink/10 max-h-96 overflow-hidden">
          <Image
            src={post.coverImageUrl}
            alt={post.title}
            fill
            className="object-cover"
            priority
            sizes="100vw"
          />
        </div>
      )}

      {/* Tartalom */}
      <article className="py-12 px-6">
        <div className="mx-auto max-w-3xl">

      <button
        type="submit"
        disabled={status === "sending"}
        className="w-full py-3 rounded-full bg-salt text-bark font-sans font-medium hover:bg-salt/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      >
